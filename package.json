{
  "name": "liwi-monorepo",
  "version": "12.0.0",
  "private": true,
  "description": "db abstraction",
  "homepage": "https://github.com/liwijs/liwi",
  "bugs": {
    "url": "https://github.com/liwijs/liwi/issues"
  },
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (http://christophe.hurpeau.com/)",
  "repository": "https://github.com/liwijs/liwi.git",
  "workspaces": [
    "packages/*",
    "@todo-example/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm run clean:build && rollup --config rollup.config.mjs && pnpm run build:definitions",
    "build:definitions": "tsc -b",
    "checks": "node scripts/check-packages.js",
    "clean": "rm -Rf docs dist test/node6 coverage",
    "clean:build": "pnpm -r --parallel run clean:build",
    "format": "oxfmt",
    "format:check": "oxfmt --check .",
    "lint": "pnpm run format && pnpm run lint:eslint",
    "lint:eslint": "NODE_OPTIONS=--max_old_space_size=4096 eslint --quiet .",
    "lint:prettier": "pob-root-prettier --check .",
    "lint:prettier:fix": "pob-root-prettier --write .",
    "prepare": "pob-root-postinstall",
    "test": "TZ=UTC node --test '@(packages|@todo-example)/*/src/**/*.test.ts'",
    "test:coverage": "TZ=UTC npx c8 --all --src ./src node --test '@(packages|@todo-example)/*/src/**/*.test.ts'",
    "test:coverage:generate": "TZ=UTC node --test '@(packages|@todo-example)/*/src/**/*.test.ts'",
    "test:watch": "TZ=UTC node --test '@(packages|@todo-example)/*/src/**/*.test.ts'",
    "tsc": "tsc -b",
    "watch": "pnpm run clean:build && rollup --config rollup.config.mjs --watch"
  },
  "devDependencies": {
    "@pob/eslint-config": "65.6.0",
    "@pob/eslint-config-typescript-react": "65.6.0",
    "@pob/rollup-esbuild": "9.1.1",
    "@pob/root": "24.3.0",
    "check-package-dependencies": "11.2.0",
    "eslint": "10.6.0",
    "typescript": "6.0.3"
  },
  "commitlint": {
    "extends": [
      "@pob/root/commitlint-config"
    ]
  },
  "browserslist": {
    "production": [
      "defaults",
      "> 0.2%",
      "not ie < 12",
      "not safari < 10",
      "not ios_saf < 10"
    ],
    "modern": [
      "defaults and >1% and supports es6-module"
    ]
  },
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">= 11.0.0"
  }
}
