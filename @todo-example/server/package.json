{
  "name": "@todo-example/server",
  "version": "13.0.1",
  "private": true,
  "homepage": "https://github.com/christophehurpeau/liwi",
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/liwi.git",
    "directory": "@todo-example/server"
  },
  "type": "module",
  "main": "./build/index-node.mjs",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "node": {
        "import": "./build/index-node.mjs"
      }
    }
  },
  "scripts": {
    "build": "pnpm run clean:build && rollup --config rollup.config.mjs",
    "clean": "pnpm run clean:build",
    "clean:build": "pob-esbuild-clean-out build",
    "lint": "pnpm run lint:eslint",
    "lint:eslint": "pnpm run --dir '../..' eslint --quiet '@todo-example/server'",
    "start": "pnpm run clean:build && rollup --config rollup.config.mjs --watch",
    "tsc": "tsc"
  },
  "dependencies": {
    "@todo-example/modules": "workspace:*",
    "alp-node": "10.1.0",
    "liwi-mongo": "workspace:*",
    "liwi-resources-server": "workspace:*",
    "liwi-resources-websocket-server": "workspace:*",
    "nightingale-app-console": "18.2.0",
    "router-segments": "12.0.0"
  },
  "devDependencies": {
    "@pob/rollup-esbuild": "9.1.1",
    "alp-rollup-plugin-config": "4.1.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "pob": {
    "bundler": "rollup-esbuild",
    "entries": [
      "index"
    ],
    "envs": [
      {
        "target": "node",
        "version": "24",
        "omitVersionInFileName": true
      }
    ],
    "typescript": true
  }
}
