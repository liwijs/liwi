{
  "name": "liwi-mongo-example",
  "version": "13.0.0",
  "private": true,
  "homepage": "https://github.com/christophehurpeau/liwi",
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/liwi.git",
    "directory": "packages/liwi-mongo-example"
  },
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./users": {
      "types": "./src/users.ts",
      "node": {
        "import": "./build/users-node.mjs"
      }
    }
  },
  "scripts": {
    "build": "pnpm run clean:build && rollup --config rollup.config.mjs",
    "clean": "pnpm run clean:build",
    "clean:build": "pob-esbuild-clean-out build",
    "lint": "pnpm run lint:eslint",
    "lint:eslint": "pnpm run --dir '../..' eslint --quiet 'packages/liwi-mongo-example'",
    "start": "pnpm run clean:build && rollup --config rollup.config.mjs --watch",
    "tsc": "tsc",
    "watch": "yarn clean:build && rollup --config rollup.config.mjs --watch"
  },
  "dependencies": {
    "liwi-mongo": "workspace:*"
  },
  "devDependencies": {
    "@pob/rollup-esbuild": "9.1.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "pob": {
    "bundler": "rollup-esbuild",
    "entries": [
      "users"
    ],
    "envs": [
      {
        "target": "node",
        "version": "24",
        "omitVersionInFileName": true
      }
    ],
    "typescript": true
  }
}
